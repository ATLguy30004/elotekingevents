<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* Skip link — visible only on focus */
.skip-link {
  position: absolute; top: -100%; left: 16px;
  background: var(--green); color: #fff;
  padding: 12px 24px; border-radius: 0 0 8px 8px;
  font-size: 16px; font-weight: 700; z-index: 200;
  text-decoration: none; transition: top 0.2s;
}
.skip-link:focus { top: 0; }

/* WCAG 2.4.7 — visible focus indicators */
a:focus-visible, button:focus-visible, summary:focus-visible,
input:focus-visible, .btn-claim:focus-visible {
  outline: 3px solid var(--green); outline-offset: 2px;
}
:root {
  --bg: #ffffff;
  --bg-soft: #f7f7f7;
  --bg-card: #ffffff;
  --text-primary: #111111;
  --text-body: #333333;
  --text-secondary: #444444;
  --text-muted: #555555;
  --green: #16a34a;
  --green-light: #22c55e;
  --green-bg: rgba(22, 163, 74, 0.08);
  --red: #dc2626;
  --red-bg: rgba(220, 38, 38, 0.08);
  --gold: #d4a017;
  --gold-bg: rgba(212, 160, 23, 0.1);
  --border: #e0e0e0;
  --border-light: #eeeeee;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);
  --radius: 12px;
  --radius-lg: 16px;
}
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg); color: var(--text-body);
  line-height: 1.6; font-size: 16px;
  -webkit-font-smoothing: antialiased; overflow-x: hidden;
}

/* ===== URGENCY BAR ===== */
.urgency-bar {
  background: var(--red); color: #fff;
  text-align: center; padding: 10px 16px;
  font-size: 14px; font-weight: 700; letter-spacing: 0.3px;
}
.urgency-bar .countdown { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 1px; }

/* ===== BADGE BAR ===== */
.badge-bar {
  background: var(--text-primary); color: #fff;
  text-align: center; padding: 10px 16px;
  font-size: 13px; font-weight: 600; letter-spacing: 0.5px;
}
.badge-bar span { color: var(--green-light); }

/* ===== LOGO BAR ===== */
.logo-bar {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  padding: 10px 16px;
  background: var(--bg);
  border-bottom: 1px solid var(--border-light);
}
.logo-bar img {
  height: 48px;
  width: auto;
  display: inline-block;
}
.logo-bar .sold-badge {
  background: var(--red); color: #fff;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px; letter-spacing: 1.5px;
  padding: 5px 12px; border-radius: 6px;
  animation: pulse-badge 2s ease-in-out infinite;
  white-space: nowrap;
}

/* ===== HERO ===== */
.hero { position: relative; overflow: hidden; background: #000; }
.hero-image-wrap {
  position: relative; width: 100%; aspect-ratio: 1/1; overflow: hidden;
}
.hero-image-wrap img {
  width: 100%; height: 100%; object-fit: cover; object-position: center 40%; display: block;
}
.hero-top-overlay {
  position: absolute; top: 0; left: 0; right: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 70%, transparent 100%);
  pointer-events: none; padding: 16px 20px 32px;
  text-align: center; z-index: 2;
}
.hero-top-overlay h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 44px; line-height: 1; letter-spacing: 2px;
  color: #fff;
  text-shadow: 0 2px 10px rgba(0,0,0,0.8);
}
.hero-image-overlay {
  position: absolute; bottom: 0; left: 0; right: 0; height: 30%;
  background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.4) 65%, transparent 100%);
  pointer-events: none;
}
@keyframes pulse-badge {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}
.hero-text-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 0 16px 16px; color: #fff;
  text-align: center; z-index: 2;
}
.hero-text-overlay .hero-sub {
  font-size: 14px; font-weight: 600; opacity: 0.95; margin-bottom: 10px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
.hero-text-overlay .hero-sub strong { color: var(--green-light); }
.hero-text-overlay .hero-address {
  font-size: 13px; opacity: 0.8; margin-bottom: 10px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
}
.hero-text-overlay .btn-claim {
  font-size: 17px; padding: 14px 24px; width: 100%; max-width: 380px; margin: 0 auto; display: block;
}

/* ===== SPOTS COUNTER ===== */
.spots-counter {
  background: #111; color: #fff;
  text-align: center; padding: 14px 20px;
  font-size: 16px; font-weight: 600;
}
.spots-counter .spots-number {
  color: var(--red); font-family: 'Bebas Neue', sans-serif;
  font-size: 24px; letter-spacing: 1px;
}
.spots-counter .spots-total {
  color: var(--text-muted); font-size: 14px;
}
.spots-counter a {
  color: var(--green-light); text-decoration: none; font-weight: 700;
  display: inline-block; min-height: 44px; line-height: 44px; padding: 0 8px;
}

/* ===== SOCIAL PROOF STRIP ===== */
.proof-strip {
  display: flex; border-top: 1px solid var(--border-light);
  border-bottom: 1px solid var(--border-light); background: var(--bg-soft);
}
.proof-item {
  flex: 1; text-align: center; padding: 16px 8px;
  border-right: 1px solid var(--border-light);
}
.proof-item:last-child { border-right: none; }
.proof-number {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 30px; color: var(--green); line-height: 1;
}
.proof-number.red { color: var(--red); }
.proof-label {
  font-size: 14px; color: var(--text-secondary); margin-top: 3px; line-height: 1.3;
  font-weight: 500;
}

/* ===== VIDEO SECTION ===== */
.video-section { padding: 28px 20px; background: var(--bg); }
.video-section h3 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px; margin-bottom: 14px; text-align: center;
  color: var(--text-primary);
}
.video-wrap {
  position: relative; width: 100%;
  aspect-ratio: 1/1;
  border-radius: var(--radius-lg); overflow: hidden;
  background: #111; cursor: pointer;
  box-shadow: var(--shadow-md);
}
.video-wrap video {
  width: 100%; height: 100%; object-fit: cover; display: block;
}
.video-play-btn {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 72px; height: 72px;
  background: rgba(255,255,255,0.95); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  pointer-events: none; z-index: 2;
  transition: transform 0.2s;
}
.video-play-btn svg { width: 28px; height: 28px; fill: var(--green); margin-left: 4px; }
.video-wrap.playing .video-play-btn { display: none; }
.video-unmute-btn {
  position: absolute; bottom: 16px; right: 16px;
  background: rgba(0,0,0,0.65); color: #fff;
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 20px; padding: 6px 14px;
  font-size: 13px; font-weight: 600; cursor: pointer;
  display: none; z-index: 3; letter-spacing: 0.3px;
  backdrop-filter: blur(4px); font-family: 'DM Sans', sans-serif;
}
.video-wrap.playing.is-muted .video-unmute-btn { display: block; }
.video-wrap.playing:not(.is-muted) .video-unmute-btn { display: none; }

/* ===== PRE-EVENT TASTING REVIEWS ===== */
.tasting-reviews { padding: 48px 20px; background: #fafafa; }
.tasting-reviews .section-title { margin-bottom: 6px; }
.tasting-reviews-sub { text-align: center; font-size: 15px; color: var(--text-muted); margin-bottom: 24px; }
.tasting-reviews-scroll {
  display: flex; gap: 16px; overflow-x: auto;
  scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
  padding-bottom: 8px;
}
.tasting-reviews-scroll::-webkit-scrollbar { height: 4px; }
.tasting-reviews-scroll::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }
.review-video-card {
  flex: 0 0 280px; scroll-snap-align: start;
  border-radius: var(--radius-lg); overflow: hidden;
  background: #111; position: relative; cursor: pointer;
  box-shadow: var(--shadow-md);
}
.review-video-card video {
  width: 100%; aspect-ratio: 9/16; object-fit: cover; display: block;
}
.review-video-card .video-play-btn {
  width: 56px; height: 56px;
}
.review-video-card .video-play-btn svg { width: 22px; height: 22px; }
.review-video-card.playing .video-play-btn { display: none; }
.review-video-card .tap-sound {
  position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.72); color: #fff; font-size: 13px; font-family: 'DM Sans', sans-serif;
  padding: 5px 12px; border-radius: 20px; pointer-events: none;
  white-space: nowrap; display: none; z-index: 3;
}
.review-video-card.muted .tap-sound { display: block; }
@media (min-width: 768px) {
  .tasting-reviews-scroll {
    display: grid; grid-template-columns: repeat(3, 1fr);
    overflow: visible;
  }
  .review-video-card { flex: none; }
}

/* ===== BRIDGE CTA ===== */
.bridge-cta { padding: 36px 20px; background: #fff; text-align: center; }
.bridge-text { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 1px; color: #111; margin-bottom: 16px; text-transform: uppercase; }
.bridge-cta .btn-claim { display: inline-block; max-width: 360px; width: 100%; }
.bridge-sub { font-size: 14px; color: var(--text-muted); margin-top: 12px; }

/* ===== TESTIMONIALS ===== */
.testimonials-section { padding: 48px 20px; background: #fff; }
.testimonials-section .section-title { margin-bottom: 6px; }
.testimonials-sub { text-align: center; font-size: 15px; color: var(--text-muted); margin-bottom: 28px; }

/* cycling card */
.review-cycle-wrap { max-width: 620px; margin: 0 auto; position: relative; min-height: 180px; }
.review-cycle-card {
  background: #f9f9f9; border: 1px solid #ebebeb; border-radius: 14px; padding: 24px 24px 20px;
  opacity: 0; transform: translateY(10px);
  transition: opacity 0.45s ease, transform 0.45s ease;
  position: absolute; inset: 0;
  pointer-events: none;
}
.review-cycle-card.active {
  opacity: 1; transform: translateY(0); position: relative; pointer-events: auto;
}
.review-cycle-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.review-cycle-avatar {
  width: 38px; height: 38px; border-radius: 50%;
  background: var(--green); color: #fff;
  font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 700;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.review-cycle-meta { flex: 1; min-width: 0; }
.review-cycle-name { font-size: 14px; font-weight: 700; color: #111; }
.review-cycle-source { font-size: 12px; color: var(--text-muted); display: flex; align-items: center; gap: 4px; margin-top: 1px; }
.review-cycle-source svg { flex-shrink: 0; }
.review-cycle-stars { color: #f59e0b; font-size: 15px; letter-spacing: 1px; margin-bottom: 10px; }
.review-cycle-quote { font-size: 14px; color: #333; line-height: 1.65; font-style: italic; }

/* dot nav */
.review-cycle-dots { display: flex; justify-content: center; gap: 8px; margin-top: 18px; }
.review-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #ddd; border: none; padding: 0; cursor: pointer; transition: background 0.2s;
}
.review-dot.active { background: var(--green); }

/* ===== MENU GRID ===== */
.menu-section { padding: 36px 20px; background: var(--bg-soft); }
.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px; margin-bottom: 20px; text-align: center;
  color: var(--text-primary);
}
.menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.menu-card {
  background: var(--bg-card); border-radius: var(--radius);
  overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid var(--border-light);
}
.menu-card-img {
  width: 100%; height: auto; display: block; background: #f0f0f0;
}
.menu-card-body { padding: 12px; }
.menu-card-name {
  font-size: 15px; font-weight: 700; color: var(--text-primary);
  line-height: 1.25; margin-bottom: 5px;
}
.menu-card-desc {
  font-size: 15px; color: var(--text-secondary); line-height: 1.45;
}
.menu-card-tag {
  display: inline-block; font-size: 13px; font-weight: 700;
  color: var(--green); background: var(--green-bg);
  padding: 3px 8px; border-radius: 4px; margin-top: 6px;
}

/* ===== GUARANTEE BAR ===== */
.guarantee-bar {
  text-align: center; padding: 16px 20px;
  background: var(--green-bg); margin: 0 20px 8px;
  border-radius: 10px; border: 1px solid rgba(22, 163, 74, 0.2);
  font-size: 16px; font-weight: 700; color: var(--green);
}
.guarantee-bar .highlight {
  background: linear-gradient(90deg, #16a34a, #22c55e, #16a34a);
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: shimmer 2s ease-in-out infinite;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== FLIGHT CARDS ===== */
.flights-section {
  padding: 36px 20px 40px;
  background: var(--bg-soft);
}
.flights-section .section-title { margin-bottom: 8px; }
.flights-sub {
  text-align: center; font-size: 16px;
  color: var(--text-secondary); margin-bottom: 20px;
  line-height: 1.5;
}
.flights-sub strong { color: var(--red); }
.highlight-pulse {
  background: rgba(22, 163, 74, 0.12);
  color: var(--green);
  padding: 2px 8px;
  border-radius: 6px;
  font-weight: 700;
  animation: highlight-glow 2.5s ease-in-out infinite;
}
@keyframes highlight-glow {
  0%, 100% { background: rgba(22, 163, 74, 0.12); }
  50% { background: rgba(22, 163, 74, 0.28); }
}
.flights-wrap {
  display: flex; flex-direction: column; gap: 20px;
}
.flight-card {
  position: relative;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2px solid var(--border-light);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  position: relative;
}
.flight-card.popular {
  border-color: var(--green);
  box-shadow: var(--shadow-lg), 0 0 0 1px var(--green);
}
.flight-card.royal {
  border-color: var(--gold);
}

/* Crown Header */
.card-crown {
  text-align: center; padding: 20px 20px 10px;
}
.crown-icon { font-size: 44px; line-height: 1; }
.tier-number {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 32px; color: var(--gold);
  line-height: 1; margin-top: -4px;
}

/* Popular Badge */
.popular-badge {
  position: absolute; top: 0; left: 0; right: 0;
  background: var(--green); color: #fff;
  text-align: center; padding: 6px;
  font-size: 14px; font-weight: 700; letter-spacing: 0.5px;
}
.popular-badge + .card-crown { padding-top: 42px; }

/* Card Body */
.card-body { padding: 0 20px 24px; }
.flight-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px; color: var(--text-primary);
  text-align: center; line-height: 1.1;
}
.flight-subtitle {
  text-align: center; font-size: 15px;
  color: var(--text-muted); margin-bottom: 16px;
}

.price-save {
  font-size: 15px; font-weight: 700;
  color: var(--green); margin-top: 10px;
  text-align: center;
}
.first-drop-counter {
  font-size: 14px; font-weight: 600;
  color: var(--red); margin-top: 8px;
}
.first-drop-counter .dot {
  display: inline-block; width: 8px; height: 8px;
  background: var(--red); border-radius: 50%;
  margin-right: 4px; vertical-align: middle;
  animation: blink 1.5s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* Progress Bar */
.drop-progress {
  margin-top: 10px;
  background: #e8e8e8;
  border-radius: 20px;
  height: 10px;
  overflow: hidden;
}
.drop-progress-fill {
  height: 100%;
  border-radius: 20px;
  background: linear-gradient(90deg, var(--green) 0%, var(--green-light) 40%, #facc15 70%, #f97316 90%, var(--red) 100%);
  background-size: 200% 100%;
  transition: width 0.6s ease;
}
.drop-progress-fill::after {
  content: '';
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 12px;
  background: rgba(255,255,255,0.4);
  border-radius: 20px;
  animation: progress-shine 1.5s ease-in-out infinite;
}
@keyframes progress-shine {
  0%, 100% { opacity: 0.2; }
  50% { opacity: 0.6; }
}
.drop-progress-label {
  display: flex; justify-content: space-between;
  font-size: 13px; font-weight: 700;
  color: var(--text-muted); margin-top: 4px;
}
.drop-progress-label .claimed { color: var(--red); }

/* Price Compare (side by side) */
.price-compare {
  display: flex; gap: 10px; margin-bottom: 16px;
}
.price-col {
  flex: 1; text-align: center; padding: 12px 8px;
  border-radius: 10px;
}
.price-col.prepay {
  background: var(--green-bg);
  border: 2px solid var(--green);
}
.price-col.door {
  background: var(--bg-soft);
  border: 2px solid var(--border);
}
.price-col-label {
  font-size: 13px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.5px; margin-bottom: 4px;
}
.price-col.prepay .price-col-label { color: var(--green); }
.price-col.door .price-col-label { color: var(--text-muted); }
.price-col-amount {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 38px; line-height: 1;
}
.price-col.prepay .price-col-amount { color: var(--text-primary); }
.price-col.door .price-col-amount {
  color: #888888; text-decoration: line-through;
}
.price-col-note {
  font-size: 13px; font-weight: 600; margin-top: 4px;
}
.price-col.prepay .price-col-note { color: var(--green); }
.price-col.door .price-col-note { color: var(--text-muted); }

/* Choose Main */
.choose-main {
  background: var(--bg-soft); border-radius: 10px;
  padding: 14px; margin-bottom: 14px;
}
.choose-label {
  font-size: 14px; font-weight: 700;
  color: var(--text-primary); margin-bottom: 8px;
  text-transform: uppercase; letter-spacing: 0.5px;
}
.choose-option {
  display: flex; justify-content: space-between;
  align-items: flex-start; padding: 6px 0;
  font-size: 15px; color: var(--text-body);
}
.choose-option > span:first-child { flex: 1; min-width: 0; }
.choose-option .item-desc { display: block; }
.choose-option .val {
  color: var(--text-muted); font-size: 14px;
  flex-shrink: 0; margin-left: 8px;
}

/* Item List */
.item-list { margin-bottom: 16px; }
.item-row {
  display: flex; justify-content: space-between;
  align-items: flex-start; padding: 8px 0;
  border-bottom: 1px solid var(--border-light);
}
.item-row:last-child { border-bottom: none; }
.item-check {
  color: var(--green); font-weight: 700;
  margin-right: 8px; flex-shrink: 0;
}
.item-name {
  flex: 1; font-size: 16px;
  color: var(--text-primary); font-weight: 500;
}
.item-desc {
  font-size: 14px; color: var(--text-muted);
  font-weight: 400;
}
.item-val {
  font-size: 15px; color: var(--text-muted);
  flex-shrink: 0; margin-left: 12px;
}

/* Add Dessert */
/* Retail value anchor */
.retail-anchor {
  text-align: center; font-size: 14px; color: var(--text-muted);
  margin-bottom: 12px;
}
.retail-anchor strong {
  font-size: 16px; color: var(--text-secondary);
  text-decoration: line-through; text-decoration-color: var(--text-muted);
}

.add-dessert {
  background: var(--gold-bg); border-radius: 10px;
  padding: 14px; margin-bottom: 16px;
  display: flex; justify-content: space-between;
  align-items: center; gap: 12px;
  cursor: pointer; user-select: none;
  border: 2px solid transparent;
  transition: border-color 0.15s;
}
.add-dessert:hover { border-color: var(--gold); }
.add-dessert.selected {
  border-color: var(--gold);
  background: #fef9eb;
}
.add-dessert.selected .add-dessert-label::before { content: "✓ "; }
.add-dessert-label {
  font-size: 14px; font-weight: 700; color: var(--gold);
}
.add-dessert-name {
  font-size: 14px; color: var(--text-body);
}
.add-dessert-desc {
  font-size: 14px; color: var(--text-muted);
}
.add-dessert-price {
  font-size: 16px; font-weight: 700; color: var(--gold);
  flex-shrink: 0;
}

/* Included dessert (Royal) */
.included-badge {
  display: inline-block; font-size: 13px; font-weight: 700;
  background: var(--green-bg); color: var(--green);
  padding: 2px 6px; border-radius: 4px; margin-left: 2px;
  vertical-align: middle;
}

/* Total Value */
.total-row {
  display: flex; justify-content: space-between;
  align-items: center; padding: 12px 0;
  border-top: 2px solid var(--border);
  margin-bottom: 16px;
}
.total-label {
  font-size: 14px; color: var(--text-muted);
}
.total-val {
  font-size: 18px; font-weight: 700; color: var(--text-muted);
  text-decoration: line-through;
}

/* CTA Button */
.btn-claim {
  display: block; width: 100%; padding: 16px;
  background: var(--green); color: #fff;
  border: none; border-radius: 10px;
  font-size: 17px; font-weight: 700;
  font-family: 'DM Sans', sans-serif;
  cursor: pointer; text-align: center;
  text-decoration: none;
  transition: background 0.2s, transform 0.1s;
}
.btn-claim:hover { background: #15803d; }
.btn-claim:active { transform: scale(0.98); }
.btn-claim.pulse {
  animation: btn-pulse 2s ease-in-out infinite;
}
@keyframes btn-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.5); }
  50% { box-shadow: 0 0 0 10px rgba(22, 163, 74, 0); }
}
.btn-claim.sold-out {
  background: #ccc; color: #888; cursor: not-allowed;
  animation: none;
}

/* Spots Left */
.card-spots-left {
  text-align: center; margin-top: 10px;
  font-size: 14px; font-weight: 600; color: var(--text-muted);
}
.card-spots-left strong { color: var(--red); }

/* Sold Out Overlay */
.sold-out-overlay {
  display: none;
  position: absolute; inset: 0;
  background: rgba(255,255,255,0.55);
  z-index: 10;
  align-items: center; justify-content: center;
  pointer-events: none;
}
.sold-out-overlay.show { display: flex; flex-direction: column; }
.sold-out-stamp {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 64px; color: var(--red);
  border: 6px solid var(--red);
  border-radius: 16px; padding: 8px 24px;
  transform: rotate(-12deg);
  letter-spacing: 4px;
}
.sold-out-door {
  margin-top: 12px;
  font-family: 'DM Sans', sans-serif;
  font-size: 18px; font-weight: 700; color: #111;
  background: #fff; padding: 8px 20px; border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transform: rotate(-12deg);
}

/* Decision helper */
.decision-helper {
  text-align: center; margin-top: 24px;
  font-size: 16px; color: var(--text-body); font-weight: 500;
}
.decision-helper strong { color: var(--green); }

/* ===== TIMELINE ===== */
.timeline-section { padding: 36px 20px; background: var(--bg); }
.timeline { max-width: 400px; margin: 0 auto; }
.timeline-step { display: flex; gap: 16px; position: relative; padding-bottom: 28px; }
.timeline-step:last-child { padding-bottom: 0; }
.timeline-rail { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.timeline-dot {
  width: 38px; height: 38px; border-radius: 50%;
  background: var(--green); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 16px; flex-shrink: 0; z-index: 1;
}
.timeline-dot.future { background: var(--bg-soft); border: 2px solid var(--border); color: var(--text-muted); }
.timeline-line { width: 2px; flex: 1; background: var(--border); margin-top: 4px; }
.timeline-step:last-child .timeline-line { display: none; }
.timeline-content { padding-top: 6px; }
.timeline-label {
  font-size: 18px; font-weight: 700; color: var(--text-primary); line-height: 1.3;
}
.timeline-date { font-size: 15px; font-weight: 700; color: var(--green); margin-top: 2px; }
.timeline-desc {
  font-size: 15px; color: var(--text-secondary); margin-top: 4px; line-height: 1.55;
}
.timeline-urgency {
  display: inline-block; margin-top: 6px; padding: 4px 10px;
  background: var(--red-bg); color: var(--red);
  font-size: 13px; font-weight: 700; border-radius: 6px;
}

/* ===== BOTTOM SECTION ===== */
.bottom-section { padding: 36px 20px 40px; background: var(--bg-soft); }
.bottom-cta-wrap {
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 28px 20px; box-shadow: var(--shadow-md);
  border: 1px solid var(--border-light); margin-bottom: 36px;
  text-align: center;
}
.bottom-cta-wrap h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px; margin-bottom: 6px; color: var(--text-primary);
}
.bottom-cta-wrap .form-sub {
  font-size: 16px; color: var(--text-secondary); margin-bottom: 20px;
  line-height: 1.5;
}
.bottom-cta-wrap .form-sub strong { color: var(--red); }
.bottom-cta-wrap .form-microcopy {
  font-size: 15px; color: var(--text-secondary); margin-top: 14px;
}

/* ===== FAQ ===== */
.faq-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px; margin-bottom: 16px; text-align: center;
  color: var(--text-primary);
}
.faq-item {
  border: 1px solid var(--border); border-radius: var(--radius);
  margin-bottom: 10px; background: var(--bg-card); overflow: hidden;
}
.faq-item summary {
  padding: 16px; font-size: 16px; font-weight: 600;
  cursor: pointer; list-style: none;
  display: flex; justify-content: space-between; align-items: center;
  color: var(--text-primary);
}
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary::after {
  content: '+'; font-size: 22px; font-weight: 400;
  color: var(--text-muted); flex-shrink: 0; margin-left: 12px;
}
.faq-item[open] summary::after { content: '\2212'; }
.faq-answer {
  padding: 0 16px 16px;
  font-size: 15px; color: var(--text-secondary); line-height: 1.65;
}

/* ===== TRUST BAR ===== */
.trust-bar {
  text-align: center; padding: 24px 20px;
  font-size: 14px; color: var(--text-secondary); font-weight: 600;
  border-top: 1px solid var(--border-light);
}
.trust-bar span { color: var(--green); margin: 0 6px; }

/* ===== STICKY BAR ===== */
.sticky-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  padding: 10px 20px; border-top: 1px solid var(--border);
  z-index: 100; box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
}
.sticky-inner { display: flex; align-items: center; gap: 12px; }
.sticky-info {
  font-size: 14px; color: var(--text-muted); line-height: 1.2;
  white-space: nowrap;
}
.sticky-info strong {
  color: var(--red); font-size: 32px; display: block;
  font-family: 'Bebas Neue', sans-serif; letter-spacing: 1.5px;
  line-height: 1;
  animation: sticky-glow 2s ease-in-out infinite;
}
@keyframes sticky-glow {
  0%, 100% { text-shadow: 0 0 4px rgba(220, 38, 38, 0.3); }
  50% { text-shadow: 0 0 12px rgba(220, 38, 38, 0.6), 0 0 24px rgba(220, 38, 38, 0.2); }
}
.sticky-bar a {
  display: block; width: 100%; padding: 14px;
  background: var(--green); color: #fff;
  text-align: center; text-decoration: none;
  border-radius: 10px; font-size: 16px; font-weight: 700;
  animation: btn-pulse 2s ease-in-out infinite;
}
.sticky-bar a:active { background: #15803d; }

/* ===== FOOTER ===== */
.footer {
  padding: 24px 20px 16px; text-align: center;
  font-size: 14px; color: var(--text-muted);
  background: var(--bg); border-top: 1px solid var(--border-light);
}
.footer { padding-bottom: 80px; }
.footer a { color: var(--green); text-decoration: none; font-weight: 600; }
.footer-links { margin-top: 6px; }


/* ===== MOBILE TIGHTENING (small phones) ===== */
@media (max-width: 374px) {
  .price-main { font-size: 40px; }
  .price-original { font-size: 20px; }
  .flight-name { font-size: 22px; }
  .choose-option { font-size: 14px; }
  .btn-claim { font-size: 15px; padding: 14px; }
  .sold-out-stamp { font-size: 48px; padding: 6px 16px; }
}

/* ===== DESKTOP (768px+) ===== */
@media (min-width: 768px) {
  /* Content sections get max-width; full-bleed bars stay edge-to-edge */
  .hero { max-width: 100%; }
  .hero-image-wrap { aspect-ratio: 16/9; max-height: 680px; min-height: 320px; }
  .hero-image-wrap img { object-position: center 50%; width: 100%; height: 100%; }
  /* Desktop hero: headline bottom-left, CTA bottom-right */
  .hero-top-overlay { top: auto; bottom: 0; background: none; padding: 0 0 32px 40px; text-align: left; }
  .hero-top-overlay h1 { font-size: 52px; text-shadow: 0 2px 12px rgba(0,0,0,0.9); }
  .hero-text-overlay { text-align: right; padding: 20px 40px 32px 20px; background: rgba(0,0,0,0.6); border-radius: 16px 0 0 0; max-width: 420px; margin-left: auto; }
  .hero-text-overlay .hero-sub { font-size: 18px; text-shadow: none; }
  .hero-text-overlay .hero-address { font-size: 16px; text-shadow: none; }
  .hero-text-overlay .btn-claim { font-size: 18px; padding: 14px 28px; width: auto; margin: 0; display: inline-block; }
  /* Hide sticky bar on desktop — spots counter already visible */
  .sticky-bar { display: none; }

  /* Proof strip */
  .proof-strip { max-width: 100%; }

  /* Video: wider */
  .video-section {
    max-width: 680px; margin-left: auto; margin-right: auto;
    padding: 36px 20px;
  }

  /* Menu grid: bigger cards */
  .menu-section {
    max-width: 1200px; margin-left: auto; margin-right: auto;
    padding: 40px 20px;
  }
  .menu-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .menu-card-img { /* full image shown, no crop */ }
  .menu-card-body { padding: 16px 18px; }
  .menu-card-name { font-size: 17px; }
  .menu-card-desc { font-size: 15px; }

  /* Flight cards: still stacked at 768px, goes horizontal at 1024px */
  .flights-section {
    max-width: 1200px; margin-left: auto; margin-right: auto;
    padding: 40px 20px 48px;
  }
  .flights-sub { font-size: 17px; }
  .guarantee-bar { font-size: 17px; }
  .decision-helper { font-size: 17px; }

  /* Timeline: wider on desktop */
  .timeline-section {
    max-width: 1200px; margin-left: auto; margin-right: auto;
    padding: 40px 20px;
  }
  .timeline { max-width: 600px; }

  /* Bottom + FAQ */
  .bottom-section {
    max-width: 1200px; margin-left: auto; margin-right: auto;
    padding: 40px 20px 48px;
  }
  .bottom-cta-wrap {
    max-width: 480px; margin-left: auto; margin-right: auto;
  }
  .faq-item { max-width: 680px; margin-left: auto; margin-right: auto; }

  .logo-bar img { height: 56px; }
}

/* ===== LARGE DESKTOP (1024px+) ===== */
@media (min-width: 1024px) {
  .hero-image-wrap { max-height: 540px; }
  .hero-top-overlay h1 { font-size: 72px; }

  /* Flight cards: side by side at 1024px+ where they have room */
  .flights-wrap {
    flex-direction: row; align-items: stretch; gap: 24px;
  }
  .flight-card { flex: 1; min-width: 0; }
  .flight-card.popular { flex: 1.15; }
  .price-col-amount { font-size: 40px; }
  .choose-option { font-size: 15px; }
  .choose-option .val { font-size: 15px; }
  .choose-label { font-size: 15px; }
  .item-name { font-size: 17px; }
  .item-desc { font-size: 15px; }
  .item-val { font-size: 16px; }
  .card-spots-left { font-size: 15px; }
  .price-save { font-size: 16px; }
  .first-drop-counter { font-size: 15px; }
  .drop-progress-label { font-size: 14px; }
  .flight-subtitle { font-size: 16px; }
}

/* ===== WCAG: Respect reduced motion preference ===== */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }
  html { scroll-behavior: auto; }
}
</style>
