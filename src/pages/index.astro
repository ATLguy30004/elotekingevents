// ===== CYCLING REVIEWS =====
(function() {
  var wrap = document.getElementById('reviewCycle');
  if (!wrap) return;
  var cards = wrap.querySelectorAll('.review-cycle-card');
  var dots = document.querySelectorAll('.review-dot');
  var current = 0;
  var timer;

  function goTo(i) {
    cards[current].classList.remove('active');
    dots[current].classList.remove('active');
    dots[current].setAttribute('aria-selected', 'false');
    current = i % cards.length;
    cards[current].classList.add('active');
    dots[current].classList.add('active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  function startTimer() {
    clearInterval(timer);
    timer = setInterval(function() { goTo(current + 1); }, 5500);
  }

  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      goTo(parseInt(dot.getAttribute('data-index'), 10));
      startTimer();
    });
  });

  // Pause on hover/focus
  wrap.addEventListener('mouseenter', function() { clearInterval(timer); });
  wrap.addEventListener('mouseleave', startTimer);
  wrap.addEventListener('focusin', function() { clearInterval(timer); });
  wrap.addEventListener('focusout', startTimer);

  startTimer();
}());

// ===== VIDEO AUTOPLAY =====
var heroVid = document.querySelector('#heroVideo');
var vidWrap = document.getElementById('videoWrap');

if (heroVid && vidWrap) {
  heroVid.muted = true;
  heroVid.playsInline = true;
  heroVid.setAttribute('playsinline', '');
  heroVid.setAttribute('webkit-playsinline', '');

  function tryPlay() {
    var p = heroVid.play();
    if (p && p.catch) p.catch(function() {});
  }

  function updatePlayState() {
    if (!heroVid.paused) {
      vidWrap.classList.add('playing');
      if (heroVid.muted) vidWrap.classList.add('is-muted');
      else vidWrap.classList.remove('is-muted');
    } else {
      vidWrap.classList.remove('playing', 'is-muted');
    }
  }
  heroVid.addEventListener('play', updatePlayState);
  heroVid.addEventListener('pause', updatePlayState);

  // Unmute button toggle
  var unmuteBtn = document.getElementById('unmuteBtn');
  if (unmuteBtn) {
    unmuteBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      heroVid.muted = !heroVid.muted;
      if (heroVid.muted) {
        vidWrap.classList.add('is-muted');
        unmuteBtn.textContent = '🔊 Tap for sound';
      } else {
        vidWrap.classList.remove('is-muted');
        unmuteBtn.textContent = '🔇 Mute';
      }
    });
  }

  // Let IntersectionObserver handle play — saves load on initial render
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        tryPlay();
      } else {
        heroVid.muted = true;
        heroVid.pause();
        vidWrap.classList.add('is-muted');
        if (unmuteBtn) unmuteBtn.textContent = '🔊 Tap for sound';
        updatePlayState();
      }
    }, { threshold: 0.3 });
    obs.observe(vidWrap);
  }

  // Also try on first user interaction as fallback
  document.addEventListener('touchstart', function startVid() {
    tryPlay();
    document.removeEventListener('touchstart', startVid);
  }, { once: true });

  updatePlayState();
}

// ===== REVIEW VIDEO TOGGLE =====
function pauseAllReviewVideos(exceptVid) {
  document.querySelectorAll('.review-video-card').forEach(function(c) {
    var v = c.querySelector('video');
    if (v && v !== exceptVid) { v.pause(); c.classList.remove('playing', 'muted'); }
  });
}

function playReviewVideo(card, vid, muted) {
  vid.muted = muted;
  if (vid.readyState === 0) { vid.load(); }
  vid.play().then(function() {
    card.classList.add('playing');
    if (muted) card.classList.add('muted'); else card.classList.remove('muted');
  }).catch(function() {
    if (!muted) {
      // Unmuted blocked (iOS) — fall back to muted
      vid.muted = true;
      vid.play().then(function() { card.classList.add('playing', 'muted'); }).catch(function() {});
    }
  });
}

function toggleReviewVideo(card) {
  var vid = card.querySelector('video');
  if (!vid) return;
  // Tap on muted auto-playing video → unmute
  if (!vid.paused && vid.muted) {
    vid.muted = false;
    card.classList.remove('muted');
    return;
  }
  if (vid.paused) {
    pauseAllReviewVideos(vid);
    playReviewVideo(card, vid, false);
  } else {
    vid.pause();
    card.classList.remove('playing', 'muted');
  }
}

// ===== REVIEW VIDEO AUTOPLAY ON SCROLL =====
if ('IntersectionObserver' in window) {
  var reviewObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      var card = entry.target;
      var vid = card.querySelector('video');
      if (!vid) return;
      if (entry.isIntersecting) {
        pauseAllReviewVideos(vid);
        playReviewVideo(card, vid, true);
      } else {
        vid.pause();
        card.classList.remove('playing', 'muted');
      }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.review-video-card').forEach(function(c) {
    reviewObserver.observe(c);
  });
}

