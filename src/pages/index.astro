<script is:inline>
// ===== COUNTDOWN TIMER =====
var EVENT_DEADLINE = new Date('2026-02-27T21:30:00-05:00').getTime();

function updateCountdown() {
  var now = Date.now();
  var diff = EVENT_DEADLINE - now;
  if (diff <= 0) {
    document.getElementById('urgencyCountdown').textContent = 'TONIGHT';
    return;
  }
  var d = Math.floor(diff / 86400000);
  var h = Math.floor((diff % 86400000) / 3600000);
  var m = Math.floor((diff % 3600000) / 60000);
  var s = Math.floor((diff % 60000) / 1000);
  document.getElementById('urgencyCountdown').textContent = d + 'd ' + h + 'h ' + m + 'm ' + s + 's';
}
updateCountdown();
var countdownInterval = setInterval(updateCountdown, 1000);
document.addEventListener('visibilitychange', function() {
  if (document.hidden) {
    clearInterval(countdownInterval);
  } else {
    updateCountdown();
    countdownInterval = setInterval(updateCountdown, 1000);
  }
});

// ===== WHATSAPP BUTTON — SHOW AFTER HERO =====
(function() {
  var wa = document.getElementById('waFloat');
  var hero = document.querySelector('.hero');
  if (wa && hero) {
    var shown = false;
    var onScroll = function() {
      var heroBottom = hero.getBoundingClientRect().bottom;
      if (heroBottom < 0 && !shown) {
        wa.style.opacity = '1';
        wa.style.pointerEvents = 'auto';
        shown = true;
      } else if (heroBottom >= 0 && shown) {
        wa.style.opacity = '0';
        wa.style.pointerEvents = 'none';
        shown = false;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
})();

// ===== PROGRESS BARS + INVENTORY =====
// Pre-pay spots per tier: The Taste = 10, King's Table = 40, Royal Feast = 10
// UPDATE THESE AS SALES COME IN:
var tierTotals = { 1: 10, 2: 40, 3: 10 };
var dropClaimed = { 1: 10, 2: 19, 3: 8 };

function updateBars() {
  var totalLeft = 0;
  for (var i = 1; i <= 3; i++) {
    var total = tierTotals[i];
    var claimed = dropClaimed[i];
    var left = total - claimed;
    var pct = (claimed / total) * 100;
    document.getElementById('bar' + i).style.width = pct + '%';
    document.getElementById('bar' + i).style.backgroundPosition = (100 - pct) + '% 0';
    document.getElementById('drop' + i).textContent = left;
    document.getElementById('claimed' + i).textContent = claimed;
    var spotsEl = document.getElementById('spots' + i);
    if (spotsEl) spotsEl.textContent = left;
    if (i === 2) totalLeft += left;
    if (left <= 0 && i !== 1) {
      var gatePrices = { 1: '22.99', 2: '44.99', 3: '74.99' };
      var overlay = document.getElementById('sold' + i);
      if (overlay) {
        overlay.classList.add('show');
      }
      var btn = document.getElementById('btn' + i);
      if (btn) {
        btn.classList.add('sold-out');
        btn.classList.remove('pulse');
        btn.textContent = 'Pay at the Door — $' + gatePrices[i];
        btn.onclick = function(e) { e.preventDefault(); };
      }
    }
  }
  document.getElementById('spotsLeft').textContent = totalLeft;
  document.getElementById('stickySpots').textContent = totalLeft;
  var tlSpots = document.getElementById('timelineSpots');
  if (tlSpots) tlSpots.textContent = totalLeft;
}
updateBars();

// ===== LIVE INVENTORY FROM VERCEL KV =====
fetch('/api/inventory')
  .then(function(r) { return r.json(); })
  .then(function(data) {
    dropClaimed[1] = Math.max(dropClaimed[1], data.t1 || 0);
    dropClaimed[2] = Math.max(dropClaimed[2], data.t2 || 0);
    dropClaimed[3] = Math.max(dropClaimed[3], data.t3 || 0);
    updateBars();
  })
  .catch(function() {}); // silently fall back to hardcoded values

// ===== TRACK SQUARE CTA CLICKS (GA4 + META) =====
console.log('[ELOTE] Tracking setup starting...');

function trackSquareClick(btn) {
  console.log('[ELOTE] Button clicked!', btn.id, btn.href);

  var tierMap = {
    'kNN8rlDP': { name: 'The Taste', value: 14.99 },
    'aN7IMSCG': { name: 'The Taste (Door Price)', value: 22.99 },
    'SYHzIroq': { name: 'The Taste + Flan (Door Price)', value: 30.99 },
    'owUPZT3F': { name: "King's Table", value: 36.99 },
    'NRHEJ7yI': { name: 'Royal Feast', value: 64.99 },
    '1Fzt6LTM': { name: 'The Taste + Flan', value: 22.99 },
    'TM7g8iDj': { name: "King's Table + Flan", value: 44.99 }
  };

  var href = btn.getAttribute('href') || '';
  var key = Object.keys(tierMap).find(function(k) { return href.indexOf(k) !== -1; });

  if (!key) {
    console.log('[ELOTE] No tier found for:', href);
    return;
  }

  var tier = tierMap[key];
  console.log('[ELOTE] Tier matched:', tier.name, '$' + tier.value);

  // Fire GA4 event
  if (typeof gtag === 'function') {
    console.log('[ELOTE] Firing GA4 begin_checkout');
    gtag('event', 'begin_checkout', {
      currency: 'USD',
      value: tier.value,
      items: [{ item_name: tier.name, price: tier.value, quantity: 1 }]
    });
  } else {
    console.log('[ELOTE] ERROR: gtag not defined!');
  }

  // Fire Meta Pixel event
  if (typeof fbq === 'function') {
    console.log('[ELOTE] Firing Meta InitiateCheckout');
    fbq('track', 'InitiateCheckout', {
      value: tier.value,
      currency: 'USD',
      content_name: tier.name
    });
  }
}

// Attach to specific buttons by ID
['btn1', 'btn2', 'btn3'].forEach(function(btnId) {
  var btn = document.getElementById(btnId);
  if (btn) {
    console.log('[ELOTE] Attached listener to', btnId, btn.href);
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var targetUrl = this.href;
      trackSquareClick(this);
      setTimeout(function() { window.location.href = targetUrl; }, 300);
    });
  } else {
    console.log('[ELOTE] Button not found:', btnId);
  }
});

// Fallback for other square.link buttons
var allSquareBtns = document.querySelectorAll('a[href*="square.link"]');
console.log('[ELOTE] Found', allSquareBtns.length, 'square.link buttons total');
allSquareBtns.forEach(function(btn) {
  if (!btn.id || (btn.id !== 'btn1' && btn.id !== 'btn2' && btn.id !== 'btn3')) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var targetUrl = this.href;
      trackSquareClick(this);
      setTimeout(function() { window.location.href = targetUrl; }, 300);
    });
  }
});

