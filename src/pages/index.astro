function handleSmsSubmit(e) {
  e.preventDefault();
  var form = document.getElementById('smsForm');
  var phone = form.querySelector('input[name="phone"]').value;
  var interest = form.querySelector('select[name="interest"]').value;

  // FORMSPREE: replace FORMSPREE_ID below with your form ID from formspree.io
  var formspreeId = 'xzdaagpz';
  if (formspreeId !== 'FORMSPREE_ID') {
    fetch('https://formspree.io/f/' + formspreeId, {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone: phone, interest: interest, source: 'sms-capture', timestamp: new Date().toISOString() })
    }).then(function(res) {
      if (res.ok) {
        form.style.display = 'none';
        document.getElementById('smsSuccess').style.display = 'block';
      } else {
        alert('Something went wrong. Please try again.');
      }
    }).catch(function() {
      alert('Connection error. Please try again.');
    });
  } else {
    form.style.display = 'none';
    document.getElementById('smsSuccess').style.display = 'block';
  }
}
