<!-- ===== ALL JS ===== -->
<script is:inline>
(function() {
    // ===== STOCK PROGRESS BARS (Event #2 gradient style) =====
    document.querySelectorAll('.menu-item[data-stock]').forEach(function(item) {
        var total = parseInt(item.dataset.stock) || 10;
        var claimed = parseInt(item.dataset.claimed) || 0;
        var remaining = total - claimed;
        var pct = Math.round((claimed / total) * 100);
        var wrap = document.createElement('div');
        wrap.className = 'stock-bar-wrap';
        var counterText;
        if (remaining <= 0) {
            counterText = 'SOLD OUT';
        } else if (remaining <= 5) {
            counterText = 'Only ' + remaining + ' left — almost gone';
        } else {
            counterText = remaining + ' left';
        }
        wrap.innerHTML =
            '<div class="stock-counter"><span class="dot"></span> ' + counterText + '</div>' +
            '<div class="stock-bar"><div class="stock-bar-fill" style="width:' + pct + '%"></div></div>' +
            '<div class="stock-labels"><span class="claimed-text">' + counterText + '</span><span></span></div>';
        item.appendChild(wrap);
    });

    // ===== VIDEO AUTOPLAY (mobile-aggressive) =====
    var allVideos = [
        document.getElementById('hero-video'),
        document.getElementById('food-reel-video')
    ].filter(Boolean);

    function tryPlay(video) {
        video.muted = true;
        video.play().catch(function() {});
    }

    // Attempt 1: immediate
    allVideos.forEach(tryPlay);

    // Attempt 2: after data loads
    allVideos.forEach(function(v) {
        v.addEventListener('canplay', function() { tryPlay(v); }, { once: true });
        v.addEventListener('loadeddata', function() { tryPlay(v); }, { once: true });
    });

    // Attempt 3: on first user touch (some mobile browsers need this)
    function onFirstTouch() {
        allVideos.forEach(tryPlay);
        document.removeEventListener('touchstart', onFirstTouch);
        document.removeEventListener('click', onFirstTouch);
    }
    document.addEventListener('touchstart', onFirstTouch, { passive: true });
    document.addEventListener('click', onFirstTouch);

    // Pause/play when scrolling in/out of view
    allVideos.forEach(function(video) {
        new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) { tryPlay(video); }
                else { video.pause(); }
            });
        }, { threshold: 0.25 }).observe(video);
    });

    // ===== COUNTDOWN =====
    var eventTime = new Date('2026-03-06T21:30:00-05:00').getTime();

    function updateCountdown() {
        var now = Date.now();
        var diff = eventTime - now;
        var el = document.getElementById('fomo-countdown');
        if (!el) return;
        if (diff <= 0) {
            el.textContent = 'EVENT IS LIVE!';
            return;
        }
        var d = Math.floor(diff / 86400000);
        var h = Math.floor((diff % 86400000) / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        el.textContent = d + 'd ' + h + 'h ' + m + 'm ' + s + 's';
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // ===== CART STATE =====
    var cart = [];

    function getCartTotal() {
        var total = 0;
        for (var i = 0; i < cart.length; i++) {
            total += cart[i].price;
        }
        return total;
    }

    function getCartCount() {
        return cart.length;
    }

    function showToast(msg) {
        var t = document.getElementById('toast');
        if (!t) return;
        t.textContent = msg;
        t.classList.add('show');
        setTimeout(function() {
            t.classList.remove('show');
        }, 2500);
    }

    function updateAllUI() {
        var count = getCartCount();
        var total = getCartTotal();
        var totalStr = '$' + total.toFixed(2);

        // Badge
        var badge = document.getElementById('cart-badge');
        if (badge) {
            badge.style.display = count > 0 ? 'flex' : 'none';
        }
        var badgeText = document.getElementById('badge-text');
        if (badgeText) {
            badgeText.textContent = count + ' item' + (count !== 1 ? 's' : '') + ' -- ' + totalStr;
        }
        var badgeCount = document.getElementById('badge-count');
        if (badgeCount) {
            badgeCount.textContent = count;
        }

        // Cart summary in menu section
        var summaryEl = document.getElementById('cart-summary');
        var summaryText = document.getElementById('cart-summary-text');
        if (summaryEl) {
            summaryEl.style.display = count > 0 ? 'block' : 'none';
        }
        if (summaryText) {
            summaryText.textContent = count + ' item' + (count !== 1 ? 's' : '') + ' -- ' + totalStr;
        }

        // Update qty counters on menu items
        var menuItems = document.querySelectorAll('.menu-item');
        for (var i = 0; i < menuItems.length; i++) {
            var name = menuItems[i].getAttribute('data-name');
            var qtyInCart = 0;
            for (var j = 0; j < cart.length; j++) {
                if (cart[j].name === name) qtyInCart++;
            }
            var qtyEl = menuItems[i].querySelector('.qty-count');
            if (qtyEl) qtyEl.textContent = qtyInCart;
        }

        // Modal items
        renderCartModal();
    }

    function renderCartModal() {
        var container = document.getElementById('cart-modal-items');
        var footer = document.getElementById('cart-modal-footer');
        var totalEl = document.getElementById('cart-modal-total-price');
        if (!container) return;

        if (cart.length === 0) {
            container.innerHTML = '<div class="cart-empty">Your cart is empty. Pick something from the menu above!</div>';
            if (footer) footer.style.display = 'none';
            return;
        }

        // Consolidate
        var consolidated = {};
        for (var i = 0; i < cart.length; i++) {
            var item = cart[i];
            if (consolidated[item.name]) {
                consolidated[item.name].quantity++;
            } else {
                consolidated[item.name] = { name: item.name, price: item.price, quantity: 1 };
            }
        }

        var html = '';
        var keys = Object.keys(consolidated);
        for (var k = 0; k < keys.length; k++) {
            var ci = consolidated[keys[k]];
            var lineTotal = (ci.price * ci.quantity).toFixed(2);
            html += '<div class="cart-modal-item">';
            html += '<div><span class="item-name">' + ci.name + '</span> <span class="item-qty">x' + ci.quantity + '</span></div>';
            html += '<div><span class="item-price">$' + lineTotal + '</span> ';
            html += '<button class="item-remove" data-name="' + ci.name + '" type="button">Remove</button></div>';
            html += '</div>';
        }

        container.innerHTML = html;
        if (footer) footer.style.display = 'block';
        if (totalEl) totalEl.textContent = '$' + getCartTotal().toFixed(2);

        // Update checkout button with total
        var checkoutBtn = document.getElementById('checkout-btn');
        if (checkoutBtn && !checkoutBtn.disabled) {
            checkoutBtn.textContent = 'Lock In My Order — $' + getCartTotal().toFixed(2);
        }

        // Bind remove buttons
        var removeBtns = container.querySelectorAll('.item-remove');
        for (var r = 0; r < removeBtns.length; r++) {
            removeBtns[r].addEventListener('click', function() {
                var nameToRemove = this.getAttribute('data-name');
                // Remove one of this item
                for (var idx = cart.length - 1; idx >= 0; idx--) {
                    if (cart[idx].name === nameToRemove) {
                        cart.splice(idx, 1);
                        break;
                    }
                }
                updateAllUI();
            });
        }
    }

    // ===== QTY BUTTONS =====
    document.addEventListener('click', function(e) {
        var btn = e.target.closest('.qty-btn');
        if (!btn) return;

        var menuItem = btn.closest('.menu-item');
        if (!menuItem) return;

        var name = menuItem.getAttribute('data-name');
        var price = parseFloat(menuItem.getAttribute('data-price'));
        var isPlus = btn.classList.contains('qty-plus');

        if (isPlus) {
            cart.push({ name: name, price: price });
            showToast(name + ' added to cart');

            // Tracking: AddToCart
            if (typeof fbq === 'function') {
                fbq('track', 'AddToCart', { content_name: name, value: price, currency: 'USD' });
            }
            if (typeof gtag === 'function') {
                gtag('event', 'add_to_cart', {
                    currency: 'USD',
                    value: price,
                    items: [{ item_name: name, price: price, quantity: 1 }]
                });
            }

            // Upsell: suggest a drink when food is added
            maybeShowDrinkUpsell(name);
        } else {
            // Remove one instance
            for (var i = cart.length - 1; i >= 0; i--) {
                if (cart[i].name === name) {
                    cart.splice(i, 1);
                    break;
                }
            }
        }

        updateAllUI();
    });

    // ===== CART BADGE / MODAL =====
    var cartBadge = document.getElementById('cart-badge');
    var openCartBtn = document.getElementById('open-cart-btn');
    var cartOverlay = document.getElementById('cart-overlay');
    var cartClose = document.getElementById('cart-close');

    function openCart() {
        if (cartOverlay) {
            cartOverlay.classList.add('active');
            renderCartModal();
        }
    }

    function closeCart() {
        if (cartOverlay) cartOverlay.classList.remove('active');
    }

    if (cartBadge) cartBadge.addEventListener('click', openCart);
    if (openCartBtn) openCartBtn.addEventListener('click', openCart);
    if (cartClose) cartClose.addEventListener('click', closeCart);
    if (cartOverlay) {
        cartOverlay.addEventListener('click', function(e) {
            if (e.target === cartOverlay) closeCart();
        });
    }

    // ===== CHECKOUT =====
    var checkoutBtn = document.getElementById('checkout-btn');
    if (checkoutBtn) {
        checkoutBtn.addEventListener('click', function() {
            if (cart.length === 0) return;

            checkoutBtn.disabled = true;
            checkoutBtn.textContent = 'Processing...';

            // Tracking: InitiateCheckout / begin_checkout
            var totalVal = getCartTotal();
            if (typeof fbq === 'function') {
                fbq('track', 'InitiateCheckout', { value: totalVal, currency: 'USD', num_items: getCartCount() });
            }
            if (typeof gtag === 'function') {
                gtag('event', 'begin_checkout', { currency: 'USD', value: totalVal });
            }

            // Consolidate cart
            var consolidated = {};
            cart.forEach(function(item) {
                if (consolidated[item.name]) {
                    consolidated[item.name].quantity++;
                } else {
                    consolidated[item.name] = { name: item.name, price: item.price, quantity: 1 };
                }
            });
            var items = Object.values(consolidated);

            fetch('/api/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: items })
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.url) {
                    window.location.href = data.url;
                } else {
                    showToast('Checkout error. Please try again.');
                    checkoutBtn.disabled = false;
                    checkoutBtn.textContent = 'Lock In My Order — $' + getCartTotal().toFixed(2);
                }
            })
            .catch(function() {
                showToast('Checkout error. Please try again.');
                checkoutBtn.disabled = false;
                checkoutBtn.textContent = 'Lock In My Order — $' + getCartTotal().toFixed(2);
            });
        });
    }

    // ===== WAITLIST FORM =====
    var waitlistForm = document.getElementById('waitlist-form');
    if (waitlistForm) {
        waitlistForm.addEventListener('submit', function(e) {
            e.preventDefault();
            var formData = new FormData(waitlistForm);

            fetch(waitlistForm.action, {
                method: 'POST',
                body: formData,
                headers: { 'Accept': 'application/json' }
            })
            .then(function(res) {
                if (res.ok) {
                    waitlistForm.style.display = 'none';
                    var success = document.getElementById('waitlist-success');
                    if (success) success.style.display = 'block';
                } else {
                    showToast('Something went wrong. Try again.');
                }
            })
            .catch(function() {
                showToast('Something went wrong. Try again.');
            });
        });
    }

    // ===== MOBILE STICKY CTA =====
    var mobileCta = document.getElementById('mobile-sticky-cta');
    if (mobileCta && window.innerWidth < 768) {
        window.addEventListener('scroll', function() {
            var hero = document.querySelector('.hero');
            if (hero && hero.getBoundingClientRect().bottom < 0) {
                mobileCta.style.display = (typeof cart !== 'undefined' && cart.length > 0) ? 'none' : 'block';
            } else {
                mobileCta.style.display = 'none';
            }
        });
    }

    // ===== DRINK UPSELL BAR =====
    var DRINK_NAMES = ['Mango Nada', 'Agua de Jamaica (Hibiscus)', 'Piña Colada'];
    var FOOD_NAMES = [
        'The Street King', "The King's Table", 'Birria Tacos (3 per order)',
        'King Smash Burger w/ Fries', 'Tornado Potato', 'Esquite (Street Corn Cup)', 'Flan'
    ];
    var upsellTimeout = null;

    function cartHasDrink() {
        for (var i = 0; i < cart.length; i++) {
            for (var d = 0; d < DRINK_NAMES.length; d++) {
                if (cart[i].name === DRINK_NAMES[d]) return true;
            }
        }
        return false;
    }

    function isFood(itemName) {
        for (var i = 0; i < FOOD_NAMES.length; i++) {
            if (FOOD_NAMES[i] === itemName) return true;
        }
        return false;
    }

    function maybeShowDrinkUpsell(addedName) {
        if (!isFood(addedName)) return;
        if (cartHasDrink()) return;

        // Remove existing upsell bar if present
        var existing = document.getElementById('upsell-bar');
        if (existing) existing.parentNode.removeChild(existing);
        if (upsellTimeout) clearTimeout(upsellTimeout);

        // Build upsell bar
        var bar = document.createElement('div');
        bar.className = 'upsell-bar';
        bar.id = 'upsell-bar';
        bar.innerHTML = '<button class="upsell-dismiss" id="upsell-dismiss" type="button">&times;</button>' +
            '<div class="upsell-bar-text">Add a drink? <span>Pi\u00f1a Colada</span> or <span>Jamaica</span> &mdash; only $3.99</div>' +
            '<div class="upsell-bar-buttons">' +
            '<button class="upsell-btn" data-drink="Pi\u00f1a Colada" type="button">+ Pi\u00f1a Colada</button>' +
            '<button class="upsell-btn" data-drink="Agua de Jamaica (Hibiscus)" type="button">+ Jamaica</button>' +
            '</div>';

        document.body.appendChild(bar);

        // Show after a brief delay for animation
        setTimeout(function() { bar.classList.add('show'); }, 50);

        // Bind dismiss
        var dismissBtn = document.getElementById('upsell-dismiss');
        if (dismissBtn) {
            dismissBtn.addEventListener('click', function() {
                hideUpsellBar();
            });
        }

        // Bind quick-add buttons
        var quickBtns = bar.querySelectorAll('.upsell-btn');
        for (var b = 0; b < quickBtns.length; b++) {
            quickBtns[b].addEventListener('click', function() {
                var drinkName = this.getAttribute('data-drink');
                cart.push({ name: drinkName, price: 3.99 });
                showToast(drinkName + ' added to cart');
                updateAllUI();
                hideUpsellBar();

                // Tracking
                if (typeof fbq === 'function') {
                    fbq('track', 'AddToCart', { content_name: drinkName, value: 3.99, currency: 'USD' });
                }
                if (typeof gtag === 'function') {
                    gtag('event', 'add_to_cart', {
                        currency: 'USD',
                        value: 3.99,
                        items: [{ item_name: drinkName, price: 3.99, quantity: 1 }]
                    });
                }
            });
        }

        // Auto-dismiss after 5 seconds
        upsellTimeout = setTimeout(function() {
            hideUpsellBar();
        }, 5000);
    }

    function hideUpsellBar() {
        var bar = document.getElementById('upsell-bar');
        if (bar) {
            bar.classList.remove('show');
            setTimeout(function() {
                if (bar.parentNode) bar.parentNode.removeChild(bar);
            }, 400);
        }
        if (upsellTimeout) {
            clearTimeout(upsellTimeout);
            upsellTimeout = null;
        }
    }

    // ===== CART ABANDONMENT SMS CAPTURE =====
    var smsTimer = null;
    var SMS_DELAY = 45000; // 45 seconds

    function startSmsTimer() {
        // Don't start if already shown this session
        if (sessionStorage.getItem('sms_capture_shown')) return;
        // Don't start if cart is empty
        if (cart.length === 0) return;

        // Clear any existing timer
        if (smsTimer) clearTimeout(smsTimer);

        smsTimer = setTimeout(function() {
            // Re-check conditions at trigger time
            if (cart.length === 0) return;
            if (sessionStorage.getItem('sms_capture_shown')) return;

            // Don't show if cart modal is open
            var cartOverlayEl = document.getElementById('cart-overlay');
            if (cartOverlayEl && cartOverlayEl.classList.contains('active')) {
                // Retry in 15 seconds
                smsTimer = setTimeout(arguments.callee, 15000);
                return;
            }

            showSmsCapture();
        }, SMS_DELAY);
    }

    function showSmsCapture() {
        sessionStorage.setItem('sms_capture_shown', '1');

        // Populate hidden fields with cart data
        var cartItemsField = document.getElementById('sms-cart-items');
        var cartTotalField = document.getElementById('sms-cart-total');
        if (cartItemsField) {
            var itemSummary = [];
            for (var i = 0; i < cart.length; i++) {
                itemSummary.push(cart[i].name + ' ($' + cart[i].price.toFixed(2) + ')');
            }
            cartItemsField.value = itemSummary.join(', ');
        }
        if (cartTotalField) {
            cartTotalField.value = '$' + getCartTotal().toFixed(2);
        }

        var scrim = document.getElementById('sms-capture-scrim');
        if (scrim) scrim.classList.add('active');
    }

    function hideSmsCapture() {
        var scrim = document.getElementById('sms-capture-scrim');
        if (scrim) scrim.classList.remove('active');
    }

    // SMS dismiss button
    var smsDismissBtn = document.getElementById('sms-capture-dismiss');
    if (smsDismissBtn) {
        smsDismissBtn.addEventListener('click', function() {
            hideSmsCapture();
        });
    }

    // SMS scrim click to dismiss
    var smsScrim = document.getElementById('sms-capture-scrim');
    if (smsScrim) {
        smsScrim.addEventListener('click', function(e) {
            if (e.target === smsScrim) hideSmsCapture();
        });
    }

    // SMS form submit
    var smsForm = document.getElementById('sms-capture-form');
    if (smsForm) {
        smsForm.addEventListener('submit', function(e) {
            e.preventDefault();

            // Update cart data right before submit
            var cartItemsField = document.getElementById('sms-cart-items');
            var cartTotalField = document.getElementById('sms-cart-total');
            if (cartItemsField) {
                var itemSummary = [];
                for (var i = 0; i < cart.length; i++) {
                    itemSummary.push(cart[i].name + ' ($' + cart[i].price.toFixed(2) + ')');
                }
                cartItemsField.value = itemSummary.join(', ');
            }
            if (cartTotalField) {
                cartTotalField.value = '$' + getCartTotal().toFixed(2);
            }

            var formData = new FormData(smsForm);

            fetch(smsForm.action, {
                method: 'POST',
                body: formData,
                headers: { 'Accept': 'application/json' }
            })
            .then(function(res) {
                if (res.ok) {
                    smsForm.style.display = 'none';
                    var successEl = document.getElementById('sms-capture-success');
                    if (successEl) successEl.style.display = 'block';
                    var dismissLink = document.getElementById('sms-capture-dismiss');
                    if (dismissLink) dismissLink.style.display = 'none';

                    // Auto-dismiss after 3 seconds
                    setTimeout(function() {
                        hideSmsCapture();
                    }, 3000);
                } else {
                    showToast('Something went wrong. Try again.');
                }
            })
            .catch(function() {
                showToast('Something went wrong. Try again.');
            });
        });
    }

    // Hook into updateAllUI to restart SMS timer when cart changes
    var _originalUpdateAllUI = updateAllUI;
    updateAllUI = function() {
        _originalUpdateAllUI();
        // Start or restart SMS abandonment timer whenever cart updates
        if (cart.length > 0 && !sessionStorage.getItem('sms_capture_shown')) {
            startSmsTimer();
        }
    };

    // ===== INIT =====
    updateAllUI();
})();
</script>
<Analytics />
<SpeedInsights />
</body>
</html>
