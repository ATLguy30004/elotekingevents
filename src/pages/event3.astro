<style>
/* ===== CSS VARIABLES ===== */
:root {
    --color-bg-dark: #ffffff;
    --color-bg-elevated: #f8f8f8;
    --color-bg-card: #f5f5f5;
    --color-text-primary: #000000;
    --color-text-secondary: #333333;
    --color-text-muted: #666666;
    --color-accent: #fbbf24;
    --color-accent-hover: #f59e0b;
    --color-border: #e0e0e0;
    --color-urgent: #ef4444;
}

/* ===== RESET & BASE ===== */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-primary);
    background: var(--color-bg-dark);
    -webkit-font-smoothing: antialiased;
}

h1, h2, h3 {
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    letter-spacing: 0.03em;
    text-transform: uppercase;
}

img, video {
    max-width: 100%;
    height: auto;
    display: block;
}

a {
    color: inherit;
    text-decoration: none;
}

/* ===== 1. FOMO BAR ===== */
.fomo-bar {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--color-urgent);
    color: #ffffff;
    text-align: center;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
}

.fomo-bar .countdown {
    background: rgba(0,0,0,0.2);
    padding: 2px 10px;
    border-radius: 9999px;
    font-variant-numeric: tabular-nums;
}

/* ===== 2. HERO ===== */
.hero {
    padding: 48px 20px 56px;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
}

.hero-video-wrapper {
    flex: 0 0 auto;
    max-width: 360px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.10);
    position: relative;
}

.hero-video-wrapper video {
    width: 100%;
    display: block;
    border-radius: 16px;
}


.hero-copy {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
}

.hero-badge {
    display: inline-block;
    background: var(--color-urgent);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
}

.hero-copy h1 {
    font-size: 3rem;
    line-height: 1.05;
    font-weight: 800;
    color: var(--color-text-primary);
}

.hero-copy h1 span {
    color: var(--color-accent-hover);
}

.hero-copy .subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
}

.urgency-bar {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}

.urgency-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #1a1a1a;
    border: 2px solid #1a1a1a;
    padding: 8px 18px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.02em;
}

.urgency-pill.hot {
    border-color: var(--color-urgent);
    color: #fff;
    background: var(--color-urgent);
    animation: pulse-urgent 2s ease-in-out infinite;
}

@keyframes pulse-urgent {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.04); }
}

.hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--color-accent);
    color: var(--color-text-primary);
    font-size: 16px;
    font-weight: 700;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    text-decoration: none;
}

.btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
}

.btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 32px;
    background: transparent;
    color: var(--color-text-primary);
    font-size: 16px;
    font-weight: 600;
    border: 2px solid var(--color-border);
    border-radius: 9999px;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.15s;
    text-decoration: none;
}

.btn-secondary:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
}

/* ===== 3. FOOD GALLERY ===== */
.food-gallery-section {
    padding: 48px 0 56px;
}

.food-gallery-section h2 {
    font-size: 2rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 4px;
    padding: 0 20px;
}

.food-gallery-section .section-sub {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 15px;
    margin-bottom: 24px;
    padding: 0 20px;
}

.food-gallery-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 20px 16px;
    scrollbar-width: none;
    justify-content: center;
    flex-wrap: wrap;
}

@media (max-width: 767px) {
    .food-gallery-scroll {
        flex-wrap: nowrap;
        justify-content: flex-start;
    }
}

.food-gallery-scroll::-webkit-scrollbar {
    display: none;
}

.food-gallery-card {
    flex: 0 0 170px;
    scroll-snap-align: start;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.10);
    text-align: center;
    background: #ffffff;
}

.food-gallery-card img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
}

.food-gallery-card .food-label {
    padding: 10px 8px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.community-block {
    max-width: 700px;
    margin: 32px auto 0;
    padding: 0 20px;
    text-align: center;
}

.community-block p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
}

.community-block p strong {
    color: var(--color-text-primary);
}

.stat-pills {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
}

.stat-pill {
    background: #1a1a1a;
    border: 2px solid #1a1a1a;
    padding: 10px 20px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.02em;
}

.stat-pill.hot {
    border-color: var(--color-urgent);
    color: #fff;
    background: var(--color-urgent);
    animation: pulse-urgent 2s ease-in-out infinite;
}

.food-gallery-cta {
    text-align: center;
    margin-top: 28px;
    padding: 0 20px;
}

/* ===== 4. PACKAGES / MENU ===== */
.packages-section {
    padding: 56px 20px;
    background: var(--color-bg-elevated);
}

.packages-inner {
    max-width: 800px;
    margin: 0 auto;
}

.packages-section h2 {
    font-size: 1.8rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 8px;
}

.packages-section .section-sub {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 32px;
    font-size: 15px;
}

.menu-category {
    margin-bottom: 32px;
}

.menu-category h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
}

.menu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    margin-bottom: 10px;
    flex-wrap: wrap;
}

.menu-item-thumb {
    width: 64px;
    height: 64px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
}

/* Sampler collage grid */
.sampler-collage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 3px;
    width: 120px;
    height: 120px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
}

.sampler-collage img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.collage-label {
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-primary);
}

/* Refund badge */
.refund-badge {
    display: inline-block;
    background: #f0fdf4;
    border: 2px solid #22c55e;
    color: #166534;
    font-size: 14px;
    font-weight: 700;
    padding: 8px 16px;
    border-radius: 9999px;
    margin-top: 8px;
    margin-bottom: 16px;
}

.sampler-tip {
    background: #fef3c7;
    border: 2px solid var(--color-accent);
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 20px;
    font-size: 14px;
    text-align: center;
    font-weight: 500;
}

.sampler-tip strong {
    font-weight: 700;
}

.menu-item-info {
    flex: 1;
    min-width: 180px;
}

.menu-item-name {
    font-weight: 700;
    font-size: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.menu-item-name .tag {
    font-size: 14px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 9999px;
    background: var(--color-accent);
    color: var(--color-text-primary);
    white-space: nowrap;
}

.menu-item-desc {
    font-size: 15px;
    color: var(--color-text-muted);
    margin-top: 2px;
}

.menu-item-price {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 16px;
    white-space: nowrap;
}

.menu-item-price .was {
    text-decoration: line-through;
    color: var(--color-text-muted);
    font-weight: 400;
    font-size: 14px;
}

.qty-controls {
    display: flex;
    align-items: center;
    gap: 0;
}

.qty-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    background: #ffffff;
    color: var(--color-text-primary);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    line-height: 1;
    padding: 0;
}

.qty-btn:hover {
    background: var(--color-accent);
}

.qty-count {
    width: 32px;
    text-align: center;
    font-weight: 700;
    font-size: 16px;
}

.cart-summary {
    margin-top: 24px;
    padding: 20px;
    background: #ffffff;
    border: 2px solid var(--color-accent);
    border-radius: 16px;
    text-align: center;
}

.cart-summary-line {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
}

.cart-summary .btn-primary {
    width: 100%;
    max-width: 360px;
}

/* ===== 5. FOOD REEL ===== */
.food-reel-section {
    padding: 56px 20px;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
}

.food-reel-section h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 24px;
}

.food-reel-video {
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 24px;
}

.food-reel-video video {
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
    aspect-ratio: 9/16;
    object-fit: cover;
    display: block;
    border-radius: 16px;
}

/* ===== 6. TESTIMONIALS ===== */
.testimonials-section {
    padding: 56px 20px;
    background: var(--color-bg-elevated);
}

.testimonials-inner {
    max-width: 1100px;
    margin: 0 auto;
}

.testimonials-section h2 {
    font-size: 1.8rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 32px;
}

.testimonials-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.testimonial-video-col {
    border-radius: 16px;
    overflow: hidden;
}

.testimonial-video-col video {
    width: 100%;
    aspect-ratio: 9/16;
    object-fit: cover;
    display: block;
    max-height: 480px;
}

.testimonial-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.testimonial-card {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 20px;
}

.testimonial-card .stars {
    color: var(--color-accent);
    font-size: 18px;
    margin-bottom: 8px;
}

.testimonial-card blockquote {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 10px;
    font-style: italic;
}

.testimonial-card .attribution {
    font-size: 14px;
    color: var(--color-text-muted);
    font-weight: 600;
}

/* ===== 7. HOW IT WORKS ===== */
.how-section {
    padding: 56px 20px;
    max-width: 900px;
    margin: 0 auto;
}

.how-section h2 {
    font-size: 1.8rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 32px;
}

.how-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
}

.how-step {
    text-align: center;
    padding: 28px 20px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 16px;
}

.how-step .step-num {
    width: 48px;
    height: 48px;
    background: var(--color-accent);
    color: var(--color-text-primary);
    font-size: 22px;
    font-weight: 800;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
}

.how-step h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 8px;
}

.how-step p {
    font-size: 15px;
    color: var(--color-text-muted);
    line-height: 1.5;
}

/* ===== 8. FAQ + CHECKOUT CARD ===== */
.faq-checkout-section {
    padding: 56px 20px;
    background: var(--color-bg-elevated);
}

.faq-checkout-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.faq-col h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 20px;
}

.faq-item {
    border-bottom: 1px solid var(--color-border);
}

.faq-item summary {
    padding: 16px 0;
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.faq-item summary::after {
    content: '+';
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text-muted);
    transition: transform 0.2s;
}

.faq-item[open] summary::after {
    content: '-';
}

.faq-item p {
    padding: 0 0 16px;
    color: var(--color-text-secondary);
    font-size: 15px;
    line-height: 1.6;
}

.checkout-card {
    background: #ffffff;
    border: 2px solid var(--color-accent);
    border-radius: 16px;
    padding: 28px 24px;
    text-align: center;
}

.checkout-card h3 {
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 8px;
}

.checkout-card .subtext {
    color: var(--color-text-muted);
    font-size: 14px;
    margin-bottom: 20px;
}

.checkout-card .btn-primary {
    width: 100%;
    margin-bottom: 20px;
}

.waitlist-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    color: var(--color-text-muted);
    font-size: 14px;
}

.waitlist-divider::before,
.waitlist-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
}

.waitlist-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.waitlist-form input {
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
}

.waitlist-form input:focus {
    border-color: var(--color-accent);
}

.waitlist-form button {
    padding: 12px 16px;
    background: var(--color-text-primary);
    color: #ffffff;
    border: none;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
}

.waitlist-form button:hover {
    opacity: 0.85;
}

.waitlist-success {
    display: none;
    padding: 16px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    color: #166534;
    font-weight: 600;
}

/* ===== 9. FLOATING CART BADGE ===== */
